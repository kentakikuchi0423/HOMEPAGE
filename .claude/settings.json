{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(npx:*)"
    ],
    "deny": [
      "Bash(git push *)",
      "Bash(git switch main)",
      "Bash(git checkout main)",
      "Bash(git merge *main*)",
      "Bash(git rebase *main*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/block-protected-git.py"
          }
        ]
      }
  }
}
